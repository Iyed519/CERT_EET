# === Cert_EET API — variables d'environnement ===
# Copier en .env pour le dev local. Ne JAMAIS committer .env.

# Environnement : development | recette | production | test
NODE_ENV=development

# Port d'écoute de l'API
PORT=3000

# Origine autorisée pour CORS (frontend Next.js en dev)
CORS_ORIGIN=http://localhost:3001

# Préfixe global des routes API (Nginx route /api -> api)
API_PREFIX=api

# --- Base de données (INF04) ---
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=cert_eet
DB_PASSWORD=change-me-database-password
DB_NAME=cert_eet

# --- Redis (déclaré, pas encore utilisé) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Bootstrap admin (seed INF04). Valeurs réelles dans .env, jamais ici. ---
ADMIN_EMAIL=admin@cert-eet.local
ADMIN_PASSWORD=change-me-to-a-strong-password
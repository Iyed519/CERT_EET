# === Cert_EET API — variables d'environnement (périmètre INF02) ===
# Copier en .env pour le dev local. Ne JAMAIS committer .env (cf. INF07).

# Environnement : development | recette | production | test
NODE_ENV=development

# Port d'écoute de l'API
PORT=3000

# Origine autorisée pour CORS (frontend Next.js en dev)
CORS_ORIGIN=http://localhost:3001

# Préfixe global des routes API (Nginx routera /api -> api en INF03)
API_PREFIX=api

# --- Branchés en INF03/INF04 (laisser vide pour l'instant) ---
# DATABASE_URL=postgresql://certeet:password@postgres:5432/certeet
# REDIS_URL=redis://redis:6379

# --- Secrets JWT RS256 : ajoutés et durcis en INF07 ---

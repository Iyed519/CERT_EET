@startuml Cert_EET_UC_Formateur_Maximal
' =====================================================================
'  Projet     : Cert_EET — Plateforme de Certification Numérique
'  Acteur     : FORMATEUR — Vue MAXIMALE (exhaustive)
'  Convention : UML 2.5 — couvre 100% de UC_Formateur_Description.md
'  Auteur     : Iyed Omri — PFE Ingénierie Logicielle, ESPRIT 2026
'  Layout     : Disposition top-to-bottom avec UC principaux en colonne
'               et sous-cas répartis en éventail (pas de chevauchements)
' =====================================================================

@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam DefaultFontName "Segoe UI"
skinparam DefaultFontSize 10
skinparam ArrowThickness 1.0
skinparam ArrowColor #6E2C00
skinparam packageStyle rectangle

' --- Layout settings critiques pour éviter les chevauchements ---
skinparam linetype polyline
skinparam nodesep 50
skinparam ranksep 100

skinparam actor {
  BackgroundColor #ECF0F1
  BorderColor #6E2C00
  BorderThickness 1.5
  FontStyle bold
}

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5D6D7E
  BorderThickness 1.0
  FontSize 10
  FontColor #1B2631
}

skinparam usecase<<main>> {
  BackgroundColor #FAE5D3
  BorderColor #6E2C00
  BorderThickness 2.0
  FontStyle bold
  FontSize 12
}

skinparam usecase<<v2>> {
  BackgroundColor #EAEDED
  BorderColor #7B7D7D
  BorderThickness 1.0
  FontSize 9
  FontStyle italic
}

skinparam package {
  BackgroundColor #FDF5EC
  BorderColor #6E2C00
  BorderThickness 1.3
  FontStyle bold
  FontSize 12
  FontColor #6E2C00
}

skinparam note {
  BackgroundColor #FEF9E7
  BorderColor #B7950B
  FontSize 9
}

title <size:15><b>Cert_EET — Cas d'Utilisation du Formateur (Vue Maximale)</b></size>\n<size:10>UC principaux (orangé) · sous-cas (blanc) · évolutions V2 (gris)</size>

' =====================================================================
'  ACTEUR PRINCIPAL — à gauche
' =====================================================================
actor "Formateur" as Formateur

' =====================================================================
'  ACTEURS SECONDAIRES — à droite
' =====================================================================
actor "Apprenant" as Apprenant
actor "API LLM" as LLM
actor "Service\nNotification" as Notif

' =====================================================================
'  ZONE 1 — Conception QCM (UC1, UC2)
' =====================================================================
package "Zone 1 · Conception QCM" {
  usecase "**UC1**\nCréer un QCM" as UC1 <<main>>

  ' Sous-cas <<include>> de UC1
  usecase "Saisir les\nmétadonnées" as UC1_Meta
  usecase "Ajouter des\nquestions" as UC1_AddQ
  usecase "Définir la\npondération" as UC1_Pond

  ' Variantes <<extend>> de UC1
  usecase "Importer\nGIFT/CSV/JSON" as UC1_Import
  usecase "Sauvegarder\nen brouillon" as UC1_Draft
  usecase "Banque de\nquestions" as UC1_Bank
  usecase "Saisir une\nexplication" as UC1_Expl
  usecase "Éditer un QCM\nexistant" as UC1_Edit

  usecase "**UC2**\nConfigurer\nl'anti-fraude" as UC2 <<main>>

  ' Sous-cas <<include>> de UC2
  usecase "Randomisation\nquestions/options" as UC2_Rnd
  usecase "Durée et\nfenêtre" as UC2_Time
  usecase "Tentatives et\ndélai minimum" as UC2_Try
  usecase "Affichage\ndes résultats" as UC2_Disp
  usecase "Seuil et\npondération" as UC2_Pass
  usecase "Publier le QCM" as UC2_Pub

  ' Variantes <<extend>> de UC2
  usecase "Piochage\nbanque" as UC2_Pool
  usecase "Sessions\nmultiples" as UC2_Multi
  usecase "Proctoring\nwebcam" as UC2_Proct
}

' =====================================================================
'  ZONE 2 — Conception Ateliers (UC3, UC4)
' =====================================================================
package "Zone 2 · Conception Ateliers" {
  usecase "**UC3**\nCréer un\natelier pratique" as UC3 <<main>>

  ' Sous-cas <<include>> de UC3
  usecase "Saisir énoncé\net ressources" as UC3_Stmt
  usecase "Modalités de\nsoumission" as UC3_Mod
  usecase "Définir la\ndate limite" as UC3_Dl
  usecase "Publier l'atelier" as UC3_Pub

  ' Variantes V2
  usecase "Atelier\ncollaboratif" as UC3_Collab <<v2>>
  usecase "Atelier à\nétapes" as UC3_Steps <<v2>>

  usecase "**UC4**\nDéfinir une grille\nde notation" as UC4 <<main>>

  ' Sous-cas <<include>> de UC4
  usecase "Ajouter\nun critère" as UC4_Add
  usecase "Pondération\n(total=100%)" as UC4_Pond

  ' Variante <<extend>>
  usecase "Enregistrer\ncomme modèle" as UC4_Tpl
}

' =====================================================================
'  ZONE 3 — Correction et Feedback (UC5, UC6)
' =====================================================================
package "Zone 3 · Correction et Feedback" {
  usecase "**UC5**\nCorriger un\nlivrable" as UC5 <<main>>

  ' Sous-cas <<include>> de UC5
  usecase "Consulter le\nlivrable soumis" as UC5_View
  usecase "Appliquer la\ngrille" as UC5_Grid
  usecase "Commentaire\npar critère" as UC5_Crit

  ' Variantes <<extend>>
  usecase "Annoter un\nfichier PDF" as UC5_Annot
  usecase "Interrompre\nen brouillon" as UC5_Pause
  usecase "Vérification\nanti-plagiat" as UC5_Plag <<v2>>

  usecase "**UC6**\nRédiger un\nfeedback structuré" as UC6 <<main>>

  ' Sous-cas <<include>>
  usecase "Commentaire\ngénéral" as UC6_Gen
  usecase "Envoyer le feedback\n(immuable)" as UC6_Send

  ' Variantes
  usecase "Joindre fichiers\nannotés" as UC6_Files
  usecase "Prévisualiser\nle rendu" as UC6_Preview
}

' =====================================================================
'  ZONE 4 — Suivi et Reporting (UC7, UC8, UC9)
' =====================================================================
package "Zone 4 · Suivi et Reporting" {
  usecase "**UC7**\nSuivre la\nprogression" as UC7 <<main>>

  usecase "Vue collective\n(KPI, histogramme)" as UC7_Coll
  usecase "Vue individuelle\n(tableau triable)" as UC7_Ind
  usecase "Fiche détaillée\nd'un apprenant" as UC7_Detail

  usecase "**UC8**\nRecevoir une alerte\nde décrochage" as UC8 <<main>>

  usecase "Consulter le détail\nde l'alerte" as UC8_View
  usecase "Marquer comme\ntraitée" as UC8_Done
  usecase "Email de synthèse\nhebdomadaire" as UC8_Mail

  usecase "**UC9**\nExporter un rapport\nde session" as UC9 <<main>>

  usecase "Choisir le type\n(global/individuel/\npar module)" as UC9_Type
  usecase "Choisir le format\n(PDF / CSV)" as UC9_Fmt
  usecase "Sélectionner\nla période" as UC9_Per
}

' =====================================================================
'  ASSOCIATIONS — Formateur → UC principaux uniquement
' =====================================================================
Formateur --> UC1
Formateur --> UC2
Formateur --> UC3
Formateur --> UC4
Formateur --> UC5
Formateur --> UC6
Formateur --> UC7
Formateur --> UC8
Formateur --> UC9

' =====================================================================
'  <<include>> — relations courtes intra-package
' =====================================================================
UC1 ..> UC1_Meta  : <<include>>
UC1 ..> UC1_AddQ  : <<include>>
UC1 ..> UC1_Pond  : <<include>>

UC2 ..> UC2_Rnd   : <<include>>
UC2 ..> UC2_Time  : <<include>>
UC2 ..> UC2_Try   : <<include>>
UC2 ..> UC2_Disp  : <<include>>
UC2 ..> UC2_Pass  : <<include>>
UC2 ..> UC2_Pub   : <<include>>

UC3 ..> UC3_Stmt  : <<include>>
UC3 ..> UC3_Mod   : <<include>>
UC3 ..> UC3_Dl    : <<include>>
UC3 ..> UC3_Pub   : <<include>>

UC4 ..> UC4_Add   : <<include>>
UC4 ..> UC4_Pond  : <<include>>

UC5 ..> UC5_View  : <<include>>
UC5 ..> UC5_Grid  : <<include>>
UC5 ..> UC5_Crit  : <<include>>

UC6 ..> UC6_Gen   : <<include>>
UC6 ..> UC6_Send  : <<include>>

UC7 ..> UC7_Coll  : <<include>>
UC7 ..> UC7_Ind   : <<include>>

UC8 ..> UC8_View  : <<include>>

UC9 ..> UC9_Type  : <<include>>
UC9 ..> UC9_Fmt   : <<include>>
UC9 ..> UC9_Per   : <<include>>

' =====================================================================
'  <<extend>> — relations courtes intra-package
' =====================================================================
UC1_Import  .> UC1 : <<extend>>
UC1_Draft   .> UC1 : <<extend>>
UC1_Bank    .> UC1 : <<extend>>
UC1_Expl    .> UC1 : <<extend>>
UC1_Edit    .> UC1 : <<extend>>

UC2_Pool    .> UC2 : <<extend>>
UC2_Multi   .> UC2 : <<extend>>
UC2_Proct   .> UC2 : <<extend>>

UC3_Collab  .> UC3 : <<extend>>
UC3_Steps   .> UC3 : <<extend>>

UC4_Tpl     .> UC4 : <<extend>>

UC5_Annot   .> UC5 : <<extend>>
UC5_Pause   .> UC5 : <<extend>>
UC5_Plag    .> UC5 : <<extend>>

UC6_Files   .> UC6 : <<extend>>
UC6_Preview .> UC6 : <<extend>>

UC7_Detail  .> UC7 : <<extend>>

UC8_Done    .> UC8 : <<extend>>
UC8_Mail    .> UC8 : <<extend>>

' =====================================================================
'  INTERACTIONS AVEC ACTEURS SECONDAIRES
' =====================================================================
UC8 ..> LLM       : <<consulte>>
UC6 ..> Notif     : <<déclenche>>
Notif --> Apprenant : notifie

' =====================================================================
'  NOTES MÉTIER
' =====================================================================
note right of UC2
  **Pourquoi UC2 est séparé de UC1 :**
  UC1 = contenu pédagogique.
  UC2 = sécurité de l'évaluation.
end note

note right of UC6
  **Contraintes pédagogiques :**
  • Commentaire général obligatoire
  • Au moins un critère commenté
  • Feedback immuable après envoi
end note

note right of UC8
  **Caractère différenciant :**
  Suivi proactif assisté par IA,
  absent des plateformes du benchmark.
end note

' =====================================================================
'  LÉGENDE
' =====================================================================
legend bottom
  | <b>Symbole</b> | <b>Signification</b> |
  | <back:#FAE5D3>  **UCx**  </back> | Cas d'utilisation **principal** |
  | <back:#FFFFFF>  sous-cas  </back> | Étape ou variante du scénario nominal |
  | <back:#EAEDED>  V2  </back> | Fonctionnalité prévue pour une **version ultérieure** |
  | <b><<include>></b> | Sous-cas **obligatoire** |
  | <b><<extend>></b> | Variante **optionnelle** |
  | <b><<consulte>></b> | Appel à un système externe |
  | <b><<déclenche>></b> | Effet de bord (notification) |
endlegend

@enduml
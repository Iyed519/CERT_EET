@startuml Cert_EET_AC01_Cycle_Certification
' =====================================================================
'  Projet    : Cert_EET — Diagramme d'activite AC-01
'  Cycle complet de certification — Apprenant | Systeme | Formateur
'  Auteur    : Iyed Omri — PFE ESPRIT 2026
'  Rendu     : PlantUML (linetype ortho). PNG de reference rendu via Graphviz.
' =====================================================================
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam DefaultFontName "Segoe UI"
skinparam DefaultFontSize 11
skinparam linetype ortho
skinparam ArrowColor #34495E
skinparam ArrowThickness 1.3
skinparam ActivityBorderThickness 1.4
skinparam ActivityDiamondBackgroundColor #FCF3CF
skinparam ActivityDiamondBorderColor #B7950B
skinparam ActivityBarColor #000000
skinparam swimlane {
  BorderColor #5D6D7E
  BorderThickness 1.6
  TitleFontStyle bold
  TitleFontSize 13
}
' Couleurs des noeuds (via #color inline) :
'   vert  #D5F5E3 = action   | bleu  #D6EAF8 = async/worker
'   jaune #FCF3CF = decision | rouge #FADBD8 = erreur/rejet
title <size:14><b>Cert_EET — AC-01 : Cycle complet de certification</b></size>\n<size:10>Apprenant : Systeme : Formateur — Inscription vers Certificat (F1.F2.F3)</size>

|#F4F8FB|Apprenant|
start
:Consulter le catalogue\ndes formations|
#D5F5E3:Demander l'inscription\na une formation;
|#F2FBF6|Systeme|
if (Places disponibles ?) then (oui)
  |Apprenant|
  #D5F5E3:Acceder aux modules\nde la formation;
  fork
    #D5F5E3:Passer les QCM requis;
  fork again
    #D5F5E3:Soumettre les livrables\ndes ateliers;
    |#FBF7F0|Formateur|
    #D5F5E3:Corriger les livrables\ndes ateliers;
  end fork
  |Systeme|
  if (Tous QCM >= seuil\nET ateliers >= seuil ?) then (oui)
    #D6EAF8:Mettre en file la generation\ndu certificat (Bull / Redis);
    #D5F5E3:Notifier l'apprenant :\ncertificat en cours;
    stop
  else (non)
    #FADBD8:Certification non eligible;
    stop
  endif
else (non)
  #FADBD8:Rejet : formation complete;
  stop
endif
@enduml

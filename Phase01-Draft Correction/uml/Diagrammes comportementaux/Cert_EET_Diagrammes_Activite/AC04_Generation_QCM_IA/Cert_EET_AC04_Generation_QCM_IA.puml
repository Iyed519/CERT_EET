@startuml Cert_EET_AC04_Generation_QCM_IA
' =====================================================================
'  Projet    : Cert_EET — Diagramme d'activite AC-04
'  Generation de questions QCM par IA / RAG — Formateur | Systeme | Worker IA | LLM externe
'  Auteur    : Iyed Omri — PFE ESPRIT 2026
'  Rendu     : PlantUML (linetype ortho). PNG de reference rendu via Graphviz.
' =====================================================================
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam DefaultFontName "Segoe UI"
skinparam DefaultFontSize 11
skinparam linetype ortho
skinparam ArrowColor #34495E
skinparam ArrowThickness 1.3
skinparam ActivityBorderThickness 1.4
skinparam ActivityDiamondBackgroundColor #FCF3CF
skinparam ActivityDiamondBorderColor #B7950B
skinparam ActivityBarColor #000000
skinparam swimlane {
  BorderColor #5D6D7E
  BorderThickness 1.6
  TitleFontStyle bold
  TitleFontSize 13
}
' Couleurs des noeuds (via #color inline) :
'   vert  #D5F5E3 = action   | bleu  #D6EAF8 = async/worker
'   jaune #FCF3CF = decision | rouge #FADBD8 = erreur/rejet
title <size:14><b>Cert_EET — AC-04 : Generation de questions QCM par IA / RAG</b></size>\n<size:10>Formateur : Systeme : Worker IA : LLM externe — pipeline 2 etages + humain dans la boucle (F4 . ADR-04/05)</size>

|#F4F8FB|Formateur|
start
#D5F5E3:Uploader un support\nde cours (PDF/PPTX);
|#F2FBF6|Systeme|
#D6EAF8:Statut = EnIndexation\n+ enfiler "indexer-support";
|#FBF7F0|Worker IA|
#D6EAF8:Extraire le texte\n+ chunker (512 / overlap 50);
fork
  |#F8F4FB|LLM externe|
  #D6EAF8:Embeddings des chunks\n(par chunk);
fork again
  |Worker IA|
  #D6EAF8:Stocker les vecteurs\n(pgvector);
end fork
#D6EAF8:Statut = Indexe\n+ notifier le formateur;
|Formateur|
#D5F5E3:Parametrer la generation\n(nb, types, niveau, focus);
|Systeme|
#D6EAF8:Enfiler "generer-questions";
|Worker IA|
#D6EAF8:Retrieval : similarite\ncosinus top-8 (pgvector);
|LLM externe|
#D6EAF8:Embeddings de la requete;
|Worker IA|
#D6EAF8:Construire le prompt\n(contexte RAG + consignes);
|LLM externe|
#D6EAF8:Chat completion\n(generation des questions);
|Worker IA|
#D6EAF8:Parser + valider\nle JSON des suggestions;
|Systeme|
#D5F5E3:INSERT suggestions\nstatut = PROPOSEE;
#D5F5E3:Notifier : suggestions\npretes a reviser;
|Formateur|
repeat
  #D5F5E3:Reviser une suggestion;
  if (Decision formateur ?) then (accepter / modifier)
    #D5F5E3:Accepter / Modifier\n(INSERT banque questions);
  else (rejeter)
    #FADBD8:Rejeter (statut = REJETEE);
  endif
repeat while (suggestions restantes ?) is (oui) not (non)
stop
@enduml

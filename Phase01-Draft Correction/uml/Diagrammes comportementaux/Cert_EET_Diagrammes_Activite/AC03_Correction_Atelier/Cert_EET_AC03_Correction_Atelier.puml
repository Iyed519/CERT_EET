@startuml Cert_EET_AC03_Correction_Atelier
' =====================================================================
'  Projet    : Cert_EET — Diagramme d'activite AC-03
'  Correction d'un atelier — Apprenant | Systeme | Formateur
'  Auteur    : Iyed Omri — PFE ESPRIT 2026
'  Rendu     : PlantUML (linetype ortho). PNG de reference rendu via Graphviz.
' =====================================================================
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam DefaultFontName "Segoe UI"
skinparam DefaultFontSize 11
skinparam linetype ortho
skinparam ArrowColor #34495E
skinparam ArrowThickness 1.3
skinparam ActivityBorderThickness 1.4
skinparam ActivityDiamondBackgroundColor #FCF3CF
skinparam ActivityDiamondBorderColor #B7950B
skinparam ActivityBarColor #000000
skinparam swimlane {
  BorderColor #5D6D7E
  BorderThickness 1.6
  TitleFontStyle bold
  TitleFontSize 13
}
' Couleurs des noeuds (via #color inline) :
'   vert  #D5F5E3 = action   | bleu  #D6EAF8 = async/worker
'   jaune #FCF3CF = decision | rouge #FADBD8 = erreur/rejet
title <size:14><b>Cert_EET — AC-03 : Correction d'un atelier</b></size>\n<size:10>Apprenant : Systeme : Formateur — Verrouillage progressif . Feedback immuable (F2 . F3)</size>

|#F4F8FB|Apprenant|
start
#D5F5E3:Soumettre le livrable\n(fichiers + commentaire);
|#F2FBF6|Systeme|
if (Avant la date limite ?) then (oui)
  if (Format et taille valides ?) then (oui)
    #D5F5E3:Statut = SOUMIS\n+ hash de tracabilite;
    |#FBF7F0|Formateur|
    #D5F5E3:Ouvrir la correction;
    |Systeme|
    #D6EAF8:Verrouillage :\nstatut = EN_CORRECTION;
    |Formateur|
    repeat
      #D5F5E3:Noter chaque critere\n(grille de notation);
    repeat while (criteres restants ?) is (oui) not (non)
    #D5F5E3:Finaliser la correction\n(commentaire general);
    |Systeme|
    if (Tous criteres notes\nET ponderations = 100% ?) then (oui)
      #D5F5E3:Statut = NOTE\n+ feedback immuable;
      #D5F5E3:Notifier l'apprenant\n(livrable corrige);
      if (Score >= seuil\nET modules valides ?) then (oui)
        #D6EAF8:Declencher l'emission\ndu certificat (AC-02 / DS-04);
        stop
      else (non)
        stop
      endif
    else (non)
      #FADBD8:Rejet : correction incomplete;
      stop
    endif
  else (non)
    #FADBD8:Rejet HTTP 400\nformat refuse;
    stop
  endif
else (non)
  #FADBD8:Rejet HTTP 403\ndate depassee;
  stop
endif
@enduml

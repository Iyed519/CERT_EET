@startuml Cert_EET_UC_Administrateur_Maximal
' =====================================================================
'  Cert_EET — ADMINISTRATEUR — Vue MAXIMALE fusionnée
'  Layout : grille 5 colonnes × 2 lignes pour format paysage compact
'  Auteur : Iyed Omri — PFE ESPRIT 2026
' =====================================================================

!theme plain

' --- Layout horizontal pour image en format paysage ---
left to right direction
skinparam linetype polyline
skinparam nodesep 25
skinparam ranksep 50

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam DefaultFontName "Segoe UI"
skinparam DefaultFontSize 10
skinparam ArrowThickness 1.0
skinparam ArrowColor #4A235A
skinparam packageStyle rectangle

skinparam actor {
  BackgroundColor #ECF0F1
  BorderColor #4A235A
  BorderThickness 1.5
  FontStyle bold
}

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5D6D7E
  FontSize 9
}

skinparam usecase<<main>> {
  BackgroundColor #E8DAEF
  BorderColor #4A235A
  BorderThickness 2.5
  FontStyle bold
  FontSize 11
}

skinparam usecase<<v2>> {
  BackgroundColor #EAEDED
  BorderColor #7B7D7D
  FontSize 8
  FontStyle italic
}

skinparam usecase<<critique>> {
  BackgroundColor #FADBD8
  BorderColor #922B21
  BorderThickness 1.5
  FontSize 9
}

skinparam package {
  BackgroundColor #F8F4FB
  BorderColor #4A235A
  BorderThickness 1.5
  FontStyle bold
  FontSize 10
  FontColor #4A235A
}

skinparam note {
  BackgroundColor #FEF9E7
  BorderColor #B7950B
  FontSize 8
}

title <size:14><b>Cert_EET — Cas d'Utilisation de l'Administrateur (Vue Maximale)</b></size>

' =====================================================================
'  ACTEUR PRINCIPAL — placé à gauche
' =====================================================================
actor "Administrateur" as Admin

' =====================================================================
'  LIGNE 1 — UC1 → UC2 → UC3 → UC4 → UC5
' =====================================================================

package "UC1 — Comptes utilisateurs" as P1 {
  usecase "**UC1**\nGérer les\ncomptes" as UC1 <<main>>
  usecase "Visualiser\nla liste" as UC1a
  usecase "Créer un\ncompte" as UC1b
  usecase "Éditer un\ncompte" as UC1c
  usecase "Email\nd'activation" as UC1d
  usecase "Import CSV" as UC1e
  usecase "Désactiver /\nRéactiver" as UC1f
  usecase "Supprimer" as UC1g <<critique>>
  usecase "Anonymiser" as UC1h

  UC1 ..> UC1a : <<include>>
  UC1 ..> UC1b : <<include>>
  UC1 ..> UC1c : <<include>>
  UC1 ..> UC1d : <<include>>
  UC1e ..> UC1 : <<extend>>
  UC1f ..> UC1 : <<extend>>
  UC1g ..> UC1 : <<extend>>
  UC1h ..> UC1 : <<extend>>
}

package "UC2 — RBAC" as P2 {
  usecase "**UC2**\nAttribuer\nles rôles" as UC2 <<main>>
  usecase "Voir rôle\net permissions" as UC2a
  usecase "Sélectionner\nun rôle" as UC2b
  usecase "Confirmer le\nchangement" as UC2c
  usecase "Invalider\nla session" as UC2d
  usecase "Auto-\nrétrogradation" as UC2e <<critique>>
  usecase "Rôles\npersonnalisés" as UC2f <<v2>>

  UC2 ..> UC2a : <<include>>
  UC2 ..> UC2b : <<include>>
  UC2 ..> UC2c : <<include>>
  UC2 ..> UC2d : <<include>>
  UC2e ..> UC2 : <<extend>>
  UC2f ..> UC2 : <<extend>>
}

package "UC3 — Formations" as P3 {
  usecase "**UC3**\nGérer les\nformations" as UC3 <<main>>
  usecase "Voir le\ncatalogue" as UC3a
  usecase "Créer une\nformation" as UC3b
  usecase "Métadonnées\net période" as UC3c
  usecase "Critères de\ncertification" as UC3d
  usecase "Modèle de\ncertificat" as UC3e
  usecase "Modifier" as UC3f
  usecase "Clôturer" as UC3g
  usecase "Archiver" as UC3h

  UC3 ..> UC3a : <<include>>
  UC3 ..> UC3b : <<include>>
  UC3 ..> UC3c : <<include>>
  UC3 ..> UC3d : <<include>>
  UC3 ..> UC3e : <<include>>
  UC3f ..> UC3 : <<extend>>
  UC3g ..> UC3 : <<extend>>
  UC3h ..> UC3 : <<extend>>
}

package "UC4 — Participants" as P4 {
  usecase "**UC4**\nAffecter\nparticipants" as UC4 <<main>>
  usecase "Voir\naffectations" as UC4a
  usecase "Affecter un\nformateur" as UC4b
  usecase "Inscrire un\napprenant" as UC4c
  usecase "Notifier les\nparticipants" as UC4d
  usecase "Import CSV\nmassif" as UC4e
  usecase "Lien public" as UC4f
  usecase "Retirer un\nparticipant" as UC4g

  UC4 ..> UC4a : <<include>>
  UC4 ..> UC4b : <<include>>
  UC4 ..> UC4c : <<include>>
  UC4 ..> UC4d : <<include>>
  UC4e ..> UC4 : <<extend>>
  UC4f ..> UC4 : <<extend>>
  UC4g ..> UC4 : <<extend>>
}

package "UC5 — Supervision certificats" as P5 {
  usecase "**UC5**\nSuperviser\ncertificats" as UC5 <<main>>
  usecase "Liste exhaustive\n(UUID, hash)" as UC5a
  usecase "Filtrer\n(période, statut)" as UC5b
  usecase "Consulter\nle détail" as UC5c
  usecase "Vue\nanalytique" as UC5d
  usecase "Exporter\n(CSV / PDF)" as UC5e

  UC5 ..> UC5a : <<include>>
  UC5 ..> UC5b : <<include>>
  UC5 ..> UC5c : <<include>>
  UC5d ..> UC5 : <<extend>>
  UC5e ..> UC5 : <<extend>>
}

' =====================================================================
'  LIGNE 2 — UC6 → UC7 → UC8 → UC9 → UC10
' =====================================================================

package "UC6 — Révocation (irréversible)" as P6 {
  usecase "**UC6**\nRévoquer un\ncertificat" as UC6 <<main>>
  usecase "Saisir motif\n(obligatoire)" as UC6a
  usecase "Joindre les\npreuves" as UC6b
  usecase "Double\nconfirmation" as UC6c <<critique>>
  usecase "MAJ page\npublique" as UC6d

  UC6 ..> UC6a : <<include>>
  UC6 ..> UC6c : <<include>>
  UC6 ..> UC6d : <<include>>
  UC6b ..> UC6 : <<extend>>
}

package "UC7 — Dashboard global" as P7 {
  usecase "**UC7**\nTableau de\nbord global" as UC7 <<main>>
  usecase "KPI globaux" as UC7a
  usecase "Graphiques\nde tendance" as UC7b
  usecase "Alertes\nsystème" as UC7c
  usecase "Activité\nrécente" as UC7d
  usecase "Filtrer par\npériode" as UC7e
  usecase "Drill-down" as UC7f

  UC7 ..> UC7a : <<include>>
  UC7 ..> UC7b : <<include>>
  UC7 ..> UC7c : <<include>>
  UC7 ..> UC7d : <<include>>
  UC7e ..> UC7 : <<extend>>
  UC7f ..> UC7 : <<extend>>
}

package "UC8 — Rapports institutionnels" as P8 {
  usecase "**UC8**\nExporter\nrapports" as UC8 <<main>>
  usecase "Choisir\nle type" as UC8a
  usecase "Définir les\nparamètres" as UC8b
  usecase "Choisir le\nformat" as UC8c
  usecase "Télécharger\nle rapport" as UC8d

  UC8 ..> UC8a : <<include>>
  UC8 ..> UC8b : <<include>>
  UC8 ..> UC8c : <<include>>
  UC8 ..> UC8d : <<include>>
}

package "UC9 — Configuration" as P9 {
  usecase "**UC9**\nConfigurer la\nplateforme" as UC9 <<main>>
  usecase "Identité\ninstitutionnelle" as UC9a
  usecase "Politiques de\nsécurité" as UC9b
  usecase "Paramètres\npédagogiques" as UC9c
  usecase "Intégrations\n(LLM, SMTP)" as UC9d
  usecase "Maintenance" as UC9e
  usecase "Intégrations\nexternes" as UC9f <<v2>>

  UC9a ..> UC9 : <<extend>>
  UC9b ..> UC9 : <<extend>>
  UC9c ..> UC9 : <<extend>>
  UC9d ..> UC9 : <<extend>>
  UC9e ..> UC9 : <<extend>>
  UC9f ..> UC9 : <<extend>>
}

package "UC10 — Audit (immuable)" as P10 {
  usecase "**UC10**\nJournaux\nd'audit" as UC10 <<main>>
  usecase "Visualiser le\njournal filtré" as UC10a
  usecase "Filtrer\n(période, type)" as UC10b
  usecase "Méta-audit" as UC10c
  usecase "Exporter\n(PDF / CSV)" as UC10d

  UC10 ..> UC10a : <<include>>
  UC10 ..> UC10b : <<include>>
  UC10 ..> UC10c : <<include>>
  UC10d ..> UC10 : <<extend>>
}

' =====================================================================
'  ACTEURS SECONDAIRES — placés à droite
' =====================================================================
actor "Service Email\n(SMTP)" as Email
actor "Service\nNotification" as Notif
actor "Utilisateur\naffecté" as User

' =====================================================================
'  ASSOCIATIONS — Admin → UC principaux
' =====================================================================
Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5
Admin --> UC6
Admin --> UC7
Admin --> UC8
Admin --> UC9
Admin --> UC10

' =====================================================================
'  DISPOSITION FORCÉE — grille 5 × 2
' =====================================================================
' Ligne 1
P1 -[hidden]right- P2
P2 -[hidden]right- P3
P3 -[hidden]right- P4
P4 -[hidden]right- P5

' Ligne 2
P6  -[hidden]right- P7
P7  -[hidden]right- P8
P8  -[hidden]right- P9
P9  -[hidden]right- P10

' Liaison verticale entre les deux lignes
P1 -[hidden]down- P6
P5 -[hidden]down- P10

' Acteurs secondaires en colonne à droite
Email -[hidden]down- Notif
Notif -[hidden]down- User

' =====================================================================
'  INTERACTIONS AVEC ACTEURS SECONDAIRES
' =====================================================================
UC1d ..> Email : <<envoie>>
UC4d ..> Email : <<envoie>>
UC2  ..> Notif : <<déclenche>>
UC6  ..> Notif : <<déclenche>>
Email --> User
Notif --> User

' =====================================================================
'  NOTES MÉTIER — compactes
' =====================================================================
note bottom of UC2
  Verrouillages : 1 admin
  actif requis, auto-rétro
  = double validation,
  session invalidée.
end note

note bottom of UC6
  IRRÉVERSIBLE : statut
  passe à "Révoqué".
  Trace cryptographique
  conservée. QR mis à jour.
end note

note bottom of UC10
  Immuabilité : logs non
  supprimables, méta-audit
  trace toute consultation.
end note

' =====================================================================
'  LÉGENDE
' =====================================================================
legend bottom
  | <b>Symbole</b> | <b>Signification</b> |
  | <back:#E8DAEF>  **UCx**  </back> | Cas d'utilisation principal |
  | <back:#FFFFFF>  sous-cas  </back> | Étape ou variante |
  | <back:#FADBD8>  critique  </back> | Action sensible |
  | <back:#EAEDED>  V2  </back> | Évolution future |
  | <b><<include>></b> | Sous-cas obligatoire |
  | <b><<extend>></b> | Variante optionnelle |
  | <b><<envoie>></b> | Vers service externe |
  | <b><<déclenche>></b> | Notification |
endlegend

@enduml
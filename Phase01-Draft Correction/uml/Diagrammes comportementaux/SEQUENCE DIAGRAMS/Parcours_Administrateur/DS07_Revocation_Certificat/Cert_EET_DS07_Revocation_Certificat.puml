@startuml Cert_EET_DS07_Revocation_Certificat
' =====================================================================
'  Projet    : Cert_EET
'  Diagramme : DS-07 — Révoquer un certificat
'  Acteur    : Administrateur
'  Ref CdC   : F3 (Certification) — UC6 Administrateur — NF3 (Audit)
'  Auteur    : Iyed Omri — PFE ESPRIT 2026
' =====================================================================
!pragma teoz true
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam DefaultFontName "Segoe UI"
skinparam DefaultFontSize 10
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 18
skinparam ArrowThickness 1.2
skinparam LifeLineBorderThickness 1.0
skinparam participant {
  BackgroundColor #FFFFFF
  BorderColor #5D6D7E
}
skinparam actor {
  BackgroundColor #ECF0F1
  BorderColor #1B4F72
  FontStyle bold
}
skinparam database {
  BackgroundColor #EBF5FB
  BorderColor #1B4F72
}
skinparam collections {
  BackgroundColor #E8F8F5
  BorderColor #1E8449
}
skinparam boundary {
  BackgroundColor #FEF9E7
  BorderColor #B7950B
}
skinparam control {
  BackgroundColor #FAE5D3
  BorderColor #BA4A00
}
skinparam note {

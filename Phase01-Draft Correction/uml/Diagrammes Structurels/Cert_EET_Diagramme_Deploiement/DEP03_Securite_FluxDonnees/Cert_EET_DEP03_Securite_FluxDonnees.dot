digraph deploiement {
  graph [rankdir=LR, splines=ortho, nodesep=0.55, ranksep=1.0,
         fontname="DejaVu Sans", fontsize=11, labelloc="t", compound=true,
         newrank=true, bgcolor="white", pad=0.4, forcelabels=true,
         label=<<b>Cert_EET — DEP-03 : Zoom securite &amp; flux de donnees</b><br/><font point-size="10">Zones de confiance · chiffrement en transit et au repos · authentification · audit (NF2 · NF3 · F7)</font><br/> >];
  node [fontname="DejaVu Sans", fontsize=10, penwidth=1.4];
  edge [fontname="DejaVu Sans", fontsize=9, color="#34495E", penwidth=1.3, arrowsize=0.8];
  subgraph cluster_z0 {
    label=<<font point-size="9"><i>«trust boundary»</i></font><br/><b>Zone non fiable</b>>;
    labelloc="t"; fontname="DejaVu Sans"; fontsize=12;
    style="filled,rounded"; fillcolor="#F2F3F4"; color="#566573"; penwidth=1.9;
    margin=16;
  u_client [shape=box, style="filled,rounded", fillcolor="#EAECEE", color="#566573", penwidth=1.5, margin="0.14,0.09", label=<<font point-size="8"><i>«untrusted»</i></font><br/><b>Client / Internet</b><br/><font point-size="8">navigateur · smartphone</font>>];
  }
  subgraph cluster_z1 {
    label=<<font point-size="9"><i>«trust boundary»</i></font><br/><b>DMZ (perimetre)</b>>;
    labelloc="t"; fontname="DejaVu Sans"; fontsize=12;
    style="filled,rounded"; fillcolor="#FBF4F2"; color="#A93226"; penwidth=1.9;
    margin=16;
  dmz_nginx [shape=box, style="filled,rounded", fillcolor="#FADBD8", color="#A93226", penwidth=1.5, margin="0.14,0.09", label=<<font point-size="8"><i>«DMZ»</i></font><br/><b>Nginx — Terminaison TLS</b><br/><font point-size="8">TLS 1.3 · HSTS · rate-limit</font>>];
  }
  subgraph cluster_z2 {
    label=<<font point-size="9"><i>«trust boundary»</i></font><br/><b>Zone applicative (fiable)</b>>;
    labelloc="t"; fontname="DejaVu Sans"; fontsize=12;
    style="filled,rounded"; fillcolor="#EFF5FB"; color="#1B4F72"; penwidth=1.9;
    margin=16;
  app_auth [shape=box, style="filled,rounded", fillcolor="#FADBD8", color="#A93226", penwidth=1.5, margin="0.14,0.09", label=<<font point-size="8"><i>«secured»</i></font><br/><b>AuthModule</b><br/><font point-size="8">JWT RS256 (cle privee)\nMFA TOTP · refresh tokens</font>>];
  app_rbac [shape=box, style="filled,rounded", fillcolor="#D6EAF8", color="#1B4F72", penwidth=1.5, margin="0.14,0.09", label=<<font point-size="8"><i>«secured»</i></font><br/><b>Garde RBAC</b><br/><font point-size="8">Admin / Formateur / Apprenant</font>>];
  app_audit [shape=box, style="filled,rounded", fillcolor="#D6EAF8", color="#1B4F72", penwidth=1.5, margin="0.14,0.09", label=<<font point-size="8"><i>«secured»</i></font><br/><b>AuditModule</b><br/><font point-size="8">journaux horodates immuables</font>>];
  }
  subgraph cluster_z3 {
    label=<<font point-size="9"><i>«trust boundary»</i></font><br/><b>Zone donnees (chiffrement au repos)</b>>;
    labelloc="t"; fontname="DejaVu Sans"; fontsize=12;
    style="filled,rounded"; fillcolor="#EAFBF1"; color="#1E8449"; penwidth=1.9;
    margin=16;
  dat_pg [shape=box, style="filled,rounded", fillcolor="#D5F5E3", color="#1E8449", penwidth=1.5, margin="0.14,0.09", label=<<font point-size="8"><i>«encrypted at rest»</i></font><br/><b>PostgreSQL</b><br/><font point-size="8">pgcrypto · SHA-256 certifs\ndonnees sensibles chiffrees</font>>];
  dat_redis [shape=box, style="filled,rounded", fillcolor="#D5F5E3", color="#1E8449", penwidth=1.5, margin="0.14,0.09", label=<<font point-size="8"><i>«in-memory»</i></font><br/><b>Redis</b><br/><font point-size="8">blacklist JWT · AOF\nsessions · rate-limit</font>>];
  dat_minio [shape=box, style="filled,rounded", fillcolor="#D5F5E3", color="#1E8449", penwidth=1.5, margin="0.14,0.09", label=<<font point-size="8"><i>«object store»</i></font><br/><b>MinIO</b><br/><font point-size="8">PDF signes · livrables</font>>];
  }
  u_client -> dmz_nginx [xlabel="HTTPS / TLS 1.3", color="#A93226", penwidth="1.9"];
  dmz_nginx -> app_auth [xlabel="JWT verifie\n(cle publique RS256)", color="#A93226", penwidth="1.6"];
  app_auth -> app_rbac [xlabel="claims + role", color="#1B4F72"];
  app_rbac -> app_audit [xlabel="action tracee", color="#1B4F72", style="dashed"];
  app_rbac -> dat_pg [xlabel="TypeORM (TLS)", color="#1E8449"];
  app_auth -> dat_redis [xlabel="blacklist / session", color="#1E8449"];
  app_audit -> dat_pg [xlabel="INSERT audit", color="#1E8449", style="dashed"];
  app_rbac -> dat_minio [xlabel="URL signee S3", color="#1E8449"];
  n_nf2 [shape=note, style=filled, fillcolor="#EAF6EE", color="#1E8449", fontsize=8.5, margin="0.12,0.08", label="NF2 Disponibilite 99% :\nrepl. PostgreSQL · cluster API"];
  dat_pg -> n_nf2 [style=dotted, arrowhead=none, color="#1E8449", constraint=false];
  n_nf3 [shape=note, style=filled, fillcolor="#FDEDEC", color="#A93226", fontsize=8.5, margin="0.12,0.08", label="NF3 : TLS bout-en-bout,\nJWT RS256, MFA, RBAC, audit"];
  app_auth -> n_nf3 [style=dotted, arrowhead=none, color="#A93226", constraint=false];
  n_f7 [shape=note, style=filled, fillcolor="#FDEDEC", color="#A93226", fontsize=8.5, margin="0.12,0.08", label="F7 Securite & conformite :\nMFA optionnelle · chiffrement repos"];
  dmz_nginx -> n_f7 [style=dotted, arrowhead=none, color="#A93226", constraint=false];
  u_client -> dmz_nginx -> app_auth -> dat_pg [style=invis, weight=20];
  app_auth -> app_rbac -> app_audit [style=invis, weight=4];
  dat_pg -> dat_redis -> dat_minio [style=invis, weight=3];
}
